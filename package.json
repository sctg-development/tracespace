{
  "name": "@sctg/tracespace",
  "private": false,
  "workspaces": [
    "apps/*",
    "config",
    "packages/*"
  ],
  "scripts": {
    "test": "cross-env INTEGRATION=1 nyc mocha",
    "test:watch": "mocha --watch --reporter dot",
    "coverage": "nyc report --reporter=lcov",
    "start": "lerna run start --parallel",
    "prebuild": "npm run clean",
    "build": "lerna run build --parallel",
    "postbuild": "npm run types",
    "watch": "concurrently \"lerna run watch --parallel\" \"npm run types -- --watch\"",
    "serve": "lerna run serve --parallel",
    "clean": "lerna run clean --parallel",
    "postclean": "npm run clean:types",
    "build:all": "lerna run build && npm run example && npm run docs",
    "lint": "eslint .",
    "format": "prettier --ignore-path .prettierignore --write '.*.@(js|yml)' '**/*.@(js|ts|tsx|json|md|yml)'",
    "types": "tsc --build",
    "clean:types": "tsc --build --clean",
    "docs": "lerna run docs",
    "example": "lerna run example",
    "prebump": "npm test",
    "bump": "lerna version",
    "publish:npm": "lerna publish from-package --yes",
    "publish:s3": "node ./scripts/publish-to-s3 apps/www/dist: apps/view/dist:view"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=24",
    "npm": "11.12.1"
  },
  "packageManager": "npm@11.12.1",
  "nyc": {
    "all": true,
    "include": [
      "apps/**",
      "packages/**"
    ],
    "exclude": [
      "**/node_modules/**",
      "**/example/**",
      "**/scripts/**",
      "**/dist/**",
      "**/integration/**",
      "**/test.js",
      "**/test/**",
      "**/__tests__/**",
      "**/*.config.js",
      "config/**",
      "packages/fixtures/**"
    ],
    "extension": [
      ".js",
      ".ts",
      ".tsx"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.29.3",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-sdk": "2.1693.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "concat-stream": "^2.0.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "debug": "^4.4.3",
    "eslint": "10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "globby": "^16.2.0",
    "lerna": "9.0.7",
    "lodash": "^4.18.1",
    "mime": "^4.1.0",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "path-browserify": "^1.0.1",
    "portfinder": "^1.0.38",
    "prettier": "^3.8.3",
    "proxyquire": "^2.1.3",
    "pump": "^3.0.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "run-parallel": "^1.2.0",
    "run-waterfall": "^1.1.7",
    "semver": "^7.7.4",
    "sinon": "^21.1.2",
    "sinon-chai": "^4.0.1",
    "snap-shot-it": "^7.9.10",
    "stream-browserify": "^3.0.0",
    "testdouble": "^3.20.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "8.0.10",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
